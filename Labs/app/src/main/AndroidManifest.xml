            android:label="@string/app_name"
            android:theme="@style/Theme._515LearnAndroid1">
        </activity>
        <activity
            android:name=".GalleryActivity"
            android:exported="false"
            android:label="Gallery Activity"
            android:theme="@style/Theme._515LearnAndroid1" />
    </application>

</manifest>